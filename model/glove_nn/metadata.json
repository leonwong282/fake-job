{
  "model_key": "glove_nn",
  "model_type": "GloVe sentence vector + Keras Sequential",
  "text_fields": [
    "title",
    "company_profile",
    "description",
    "requirements",
    "benefits"
  ],
  "target_col": "fraudulent",
  "preprocess": [
    "lowercase",
    "remove_links",
    "remove_html",
    "remove_punctuation",
    "remove_digits_words",
    "regexp_tokenize",
    "remove_english_stopwords",
    "join_tokens_with_space"
  ],
  "threshold": 0.5,
  "encoder_type": "glove_sentence_vector",
  "embedding_dim": 200
}