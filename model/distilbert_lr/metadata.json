{
  "model_key": "distilbert_lr",
  "model_type": "DistilBERT Embedding + LogisticRegression",
  "text_fields": [
    "title",
    "company_profile",
    "description",
    "requirements",
    "benefits"
  ],
  "target_col": "fraudulent",
  "preprocess": [
    "lowercase",
    "remove_links",
    "remove_html",
    "remove_punctuation",
    "remove_digits_words",
    "regexp_tokenize",
    "remove_english_stopwords",
    "join_tokens_with_space"
  ],
  "threshold": 0.5,
  "encoder_type": "transformer_embedding",
  "model_name": "distilbert-base-uncased",
  "max_len": 128,
  "batch_size": 16
}